{
  "version": 3,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "WINDOW_ENGINE_ENABLE_TESTS": "ON",
        "WINDOW_ENGINE_DEV_BUILD": "ON",
        "WOZZITS_ENABLE_V8_SCRIPTING": "OFF"
      }
    },
    {
      "name": "windows-debug",
      "displayName": "Windows x64 Debug",
      "description": "Debug build using MSVC + Ninja. Run from a VS 2022 Developer Command Prompt.",
      "inherits": "base",
      "generator": "Ninja",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "windows-release",
      "displayName": "Windows x64 Release",
      "description": "Release build using MSVC + Ninja.",
      "inherits": "base",
      "generator": "Ninja",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-debug",
      "displayName": "Windows x64 Debug",
      "configurePreset": "windows-debug"
    },
    {
      "name": "windows-release",
      "displayName": "Windows x64 Release",
      "configurePreset": "windows-release"
    }
  ],
  "testPresets": [
    {
      "name": "windows-debug",
      "displayName": "Windows x64 Debug",
      "configurePreset": "windows-debug",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "windows-release",
      "displayName": "Windows x64 Release",
      "configurePreset": "windows-release",
      "output": { "outputOnFailure": true }
    }
  ]
}
